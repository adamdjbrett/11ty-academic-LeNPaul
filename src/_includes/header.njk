<header class="d-flex flex-column flex-md-row align-items-center pb-3 mb-5 border-bottom" role="banner">
  <div>
    <a href="/" class="d-flex align-items-center text-decoration-none">
      {% if page.url == "/" %}
        <h1 class="fs-4 fw-bold m-0">{{ site.title }}</h1>
      {% else %}
        <span class="fs-4 fw-bold">{{ site.title }}</span>
      {% endif %}
    </a>
    <a href="/" class="d-flex align-items-center text-decoration-none">
      <span>{{ site.description }}</span>
    </a>
  </div>
  <nav class="d-inline-flex mt-2 mt-md-0 ms-md-auto" role="navigation" aria-label="Main Navigation">
    {% for item in menu %}
      <a class="me-3 py-2 text-decoration-none" href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.name }}</a>
    {% endfor %}
  </nav>
</header>
