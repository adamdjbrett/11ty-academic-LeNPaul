<div class="row g-5 mb-5">
  <div class="col-md-12">
    <h3 class="fw-bold border-bottom pb-3 mb-5">Featured Publications</h3>
    {% if layout == "home.njk" %}
      {% for item in publicationsData %}
        {% if item.featured %}
          <p><a href="/publications/{{ item.url }}/">{{ item.name }}</a></p>
        {% endif %}
      {% endfor %}
    {% else %}
      {% for item in publicationsData %}
        <p><a href="/publications/{{ item.url }}/">{{ item.name }}</a></p>
      {% endfor %}
    {% endif %}
  </div>
</div>
