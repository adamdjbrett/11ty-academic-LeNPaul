---
layout: default.njk
---

<div class="row g-5 mb-5">
  <div class="col-md-12">
    <h3 class="fw-bold border-bottom pb-3 mb-5">People</h3>
    {% for person in people %}
      <div class="row g-5 mb-5">
        <div class="col-md-6">
          <p><strong>Name:</strong> {{ person.name }}</p>
          <p><strong>Email:</strong> <a href="mailto:{{ person.email }}">{{ person.email }}</a></p>
          <p><strong>Phone:</strong> {{ person.phone }}</p>
          <p><a href="/people/{{ person.url }}/">More info</a></p>
        </div>
        <div class="col-md-6">
          <img src="{{ person.image }}" alt="{{ person.name }}" width="100%">
        </div>
      </div>
    {% endfor %}
  </div>
</div>
