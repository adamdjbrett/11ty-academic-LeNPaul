---
layout: default.njk
---

<div class="row g-5 mb-5">
  <div class="col-md-12">
    {{ content | safe }}
  </div>
</div>

<div class="row g-5 mb-5">
  <div class="col-md-12">
    <h3 class="fw-bold border-bottom pb-3 mb-5">Courses</h3>
    {% for course in coursesData %}
      <p><a href="/courses/{{ course.url }}/">{{ course.name }}</a></p>
    {% endfor %}
  </div>
</div>
