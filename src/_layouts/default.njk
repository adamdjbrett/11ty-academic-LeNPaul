<!doctype html>
<html lang="{{ lang | default('en-US') }}">
  {% include "head.njk" %}

  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="col-lg-8 mx-auto p-3 py-md-5">
      {% include "header.njk" %}
      <main id="main-content">
        {{ content | safe }}
      </main>
      <!-- outputs all the icons used on the page -->
      {% getBundle "fontawesome" %}
      {% include "footer.njk" %}
    </div>
  </body>
</html>
