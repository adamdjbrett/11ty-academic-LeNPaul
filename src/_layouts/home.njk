---
layout: default.njk
---

<div class="row g-5 mb-5">
  <div class="col-md-6">
    <h3 class="fw-bold">Research</h3>
    {{ content | safe }}
  </div>
  <div class="col-md-6">
    <img src="/assets/img/home.jpg" alt="Home" width="100%">
  </div>
</div>

{% include "publications.njk" %}

<div class="row g-5 mb-5">
  <div class="col-md-12">
    <h3 class="fw-bold border-bottom pb-3 mb-5">Updates</h3>
    {% for post in collections.posts %}
      <p><a href="{{ post.url }}">{{ post.data.title }}</a> - {{ post.date | dateFormat }}</p>
    {% endfor %}
  </div>
</div>
